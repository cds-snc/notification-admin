# tests_perf env example
# Copy this file to tests_perf/.env and fill values.

PERF_API_BASE_URL=http://localhost:6011
PERF_ADMIN_BASE_URL=http://localhost:6012
PERF_CYPRESS_AUTH_USER_NAME=CYPRESS_AUTH_USER
PERF_CYPRESS_AUTH_CLIENT_SECRET=replace_me
PERF_USER_PASSWORD=replace_me
PERF_TARGET_SERVICE_ID=replace_me

# Optional
# PERF_USER_COUNT=10
# PERF_2FA_CODE=12345
# PERF_ACCOUNTS_FILE=/tmp/tests_perf_accounts.json
# PERF_ADD_TO_SERVICE_URL_TEMPLATE={base_url}/service/{service_id}/users/{user_id}
# PERF_ADD_TO_SERVICE_METHOD=POST
